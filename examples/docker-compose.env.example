# ComfyUI Docker Environment Configuration Example\n# Copy this file to .env and fill in your values\n\n# ================================\n# Authentication Tokens (Optional)\n# ================================\n\n# HuggingFace Hub Authentication\n# Get your token from: https://huggingface.co/settings/tokens\n# Format: hf_ followed by 34 characters\nHUGGINGFACE_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx\n\n# CivitAI API Authentication  \n# Get your API key from: https://civitai.com/user/account\n# Format: 32-character hexadecimal string\nCIVITAI_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\n\n# Authentication Settings\nAUTO_LOGIN=true\n\n# ================================\n# Service Configuration\n# ================================\n\n# Port Configuration\nCOMFYUI_PORT=8188\nJUPYTER_PORT=8888\n\n# Security\nJUPYTER_TOKEN=your-secure-jupyter-token-here\nJUPYTER_PASSWORD=\n\n# ================================\n# Storage Configuration\n# ================================\n\n# Model Storage\nMODEL_CACHE_DIR=/workspace/models\nHF_HOME=/workspace/.cache/huggingface\n\n# Workspace Path (Host Machine)\nWORKSPACE_PATH=./workspace\n\n# ================================\n# Logging & Performance\n# ================================\n\n# Logging Level: DEBUG, INFO, WARNING, ERROR\nLOG_LEVEL=INFO\n\n# Setup Timeout (seconds)\nSETUP_TIMEOUT=300\n\n# Startup Delay (seconds)\nSTARTUP_DELAY=2\n\n# ================================\n# Usage Examples\n# ================================\n\n# Basic usage:\n# docker run -it --rm -p 8188:8188 -p 8888:8888 --env-file .env -v $(pwd)/workspace:/workspace myuser/comfyui:latest\n\n# Production usage:\n# docker run -d --name comfyui-prod --restart unless-stopped -p 8188:8188 -p 8888:8888 --env-file .env -v /data/comfyui:/workspace myuser/comfyui:latest" 